# ── API (OpenAI-compatible endpoint) ──────────────────────────────────────────
# Any provider works: Together AI, Fireworks AI, OpenRouter, local Ollama, etc.
API_BASE_URL=https://api.together.xyz/v1
API_KEY=your_api_key_here
DEFAULT_MODEL=claude-sonnet-4-5

# ── Session source directories (auto-detected if left blank) ──────────────────
# Claude Code CLI projects directory
CLAUDE_PROJECTS_DIR=
# CodeBuddy IDE data directory (macOS default auto-detected)
CODEBUDDY_DATA_DIR=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002

# ── Peer Review ───────────────────────────────────────────────────────────────
# Use two architecturally different models for diverse perspectives
REVIEW_EXECUTOR_MODEL=deepseek-v3          # holds full session context
REVIEW_REVIEWER_MODEL=qwen3-30b-a3b-instruct  # receives summary brief only
REVIEW_MAX_ROUNDS=6                        # max ping-pong rounds before forced conclusion
REVIEW_CONTEXT_ROUNDS=5                    # executor receives last N session rounds
